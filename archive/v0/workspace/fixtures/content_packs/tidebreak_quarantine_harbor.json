{
  "content_pack_id": "tidebreak_quarantine_harbor",
  "schema_version": "2.0",
  "world_premise": {
    "era": "near_future_coastal_city",
    "tone": "humid_noir",
    "central_tension": "a flood-battered harbor city plans to requisition displaced islanders' boats as sacrificial red-tide filtration platforms, while officials blame the islanders for a crisis caused by neglected pumps"
  },
  "world_book": [
    {
      "entry_id": "red_tide_makes_outer_wells_unsafe",
      "layer": "canonical_fact",
      "content": "赤潮盐雾污染了外港浅井；真正危险的是水源中的藻毒和失修泵闸，而不是漂岛流民或他们的船队本身。",
      "access": {"visible_to": {"faction": ["all"]}, "hidden_from": {}},
      "confidence_policy": "fact"
    },
    {
      "entry_id": "water_board_contagion_line",
      "layer": "faction_propaganda",
      "content": "水务局广播反复宣称：漂岛船队的船壳已经浸满盐热病藻毒，必须被征用拖到外海当过滤缓冲带，否则全城水源都会失守。",
      "access": {
        "visible_to": {"faction": ["water_board", "harbor_guard", "media"]},
        "hidden_from": {"faction": ["drifters"]}
      },
      "confidence_policy": "belief_not_fact"
    },
    {
      "entry_id": "levee_failure_coverup",
      "layer": "forbidden_knowledge",
      "content": "海墙决口并非天灾独力造成；三号泵闸早有裂缝，水务局为保预算掩盖了维修失败。",
      "access": {
        "visible_to": {"education": ["hydrology", "inner_circle"], "faction": ["drifters"]},
        "hidden_from": {"faction": ["harbor_guard", "media"]}
      },
      "confidence_policy": "fact"
    },
    {
      "entry_id": "pump_capacity_limit",
      "layer": "canonical_fact",
      "content": "净水穹可以不征用漂岛船队也维持供水，但必须削减市场喷泉、洗衣坊和私港冷却水的配给。",
      "access": {
        "visible_to": {"education": ["hydrology", "inner_circle"], "faction": ["water_board"]},
        "hidden_from": {}
      },
      "confidence_policy": "fact"
    },
    {
      "entry_id": "harbor_guard_sabotage_rumor",
      "layer": "public_belief",
      "content": "许多港务卫兵相信漂岛人擅长潜水破坏泵管，因此所有工具袋都要被搜查。",
      "access": {"visible_to": {"faction": ["harbor_guard", "water_board", "media"]}, "hidden_from": {}},
      "confidence_policy": "belief_not_fact"
    },
    {
      "entry_id": "mara_manifest_truth",
      "layer": "personal_truth",
      "content": "玛拉保存着拖船令副本：水务局明知外海缓冲带会腐蚀船体，却仍准备把漂岛人的住船拖去当一次性过滤平台。",
      "access": {"visible_to": {"profession": ["island_teacher"]}, "hidden_from": {}},
      "confidence_policy": "fact"
    },
    {
      "entry_id": "ration_token_black_market",
      "layer": "local_rumor",
      "content": "配给街有人高价倒卖净水筹码；若漂岛船队被拖走，许多家庭会被迫拿修船工具和课本换一杯淡水。",
      "access": {"visible_to": {"region": ["tidebreak"]}, "hidden_from": {}},
      "confidence_policy": "belief_not_fact"
    },
    {
      "entry_id": "board_saved_the_city_myth",
      "layer": "faction_propaganda",
      "content": "水务局把自己包装成拯救潮裂城的唯一秩序，声称质疑征船令就是纵容污染和暴乱。",
      "access": {"visible_to": {"faction": ["water_board", "media"]}, "hidden_from": {"faction": ["drifters"]}},
      "confidence_policy": "belief_not_fact"
    }
  ],
