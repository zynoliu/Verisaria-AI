    "central_tension": "风雪封山的边境哨站，渐少的过冬补给与陈年的教会宣传，把对恶魔难民的恐惧推成了公开的猜忌。"
  },
  "world_book": [
    {
      "entry_id": "demons_are_real_people",
      "layer": "canonical_fact",
      "content": "恶魔族群确实存在，有自己的语言、家庭和文明；他们和人类一样会饥饿、会害怕。",
      "access": {"visible_to": {"faction": ["all"]}, "hidden_from": {}},
      "confidence_policy": "fact"
    },
    {
      "entry_id": "church_demon_propaganda",
      "layer": "faction_propaganda",
      "content": "圣焰教会宣称：恶魔是一切灾祸的根源，凡接纳恶魔者必招厄运。",
      "access": {"visible_to": {"faction": ["watch", "church"]}, "hidden_from": {"faction": ["refugees"]}},
      "confidence_policy": "belief_not_fact"
    },
    {
      "entry_id": "massacre_at_the_pass",
      "layer": "forbidden_knowledge",
      "content": "二十年前，守军曾屠杀过一支前来求和的恶魔使节队——此事被教会从记录中抹去。",
      "access": {"visible_to": {"faction": ["refugees"]}, "hidden_from": {"faction": ["watch", "church"]}},
      "confidence_policy": "fact"
    },
    {
      "entry_id": "supplies_running_low",
      "layer": "local_rumor",
      "content": "哨站的过冬粮只够再撑半个月，没人知道下一批补给何时能翻过雪山。",
      "access": {"visible_to": {"region": ["frostgate"]}, "hidden_from": {}},
      "confidence_policy": "belief_not_fact"
    }
  ],
  "starting_location": "gatehouse",
  "initial_locations": [
    {
      "location_id": "gatehouse",
      "name": "门楼",
      "description": "风从箭垛的缝隙里灌进来，火盆只够暖住围着它的几个人。结霜的吊闸后面，就是被关在城外的难民营。",
      "connections": [
        {"to": "barracks", "distance": "adjacent", "noise_leak": 0.2, "visual_leak": 0.1, "description": "推开结霜的木门，进入兵营"},
        {"to": "refugee_camp", "distance": "near", "noise_leak": 0.1, "visual_leak": 0.0, "description": "穿过结冰的吊桥，走向城墙外的难民营"}
      ]
