    {
      "location_id": "barracks",
      "name": "兵营",
      "description": "一排空了大半的木床，墙角堆着越来越矮的粮袋。守军在这里低声议论，话题离不开补给和城外那群人。",
      "connections": [
        {"to": "gatehouse", "distance": "adjacent", "noise_leak": 0.2, "visual_leak": 0.1, "description": "回到风雪呼啸的门楼"}
      ]
    },
    {
      "location_id": "refugee_camp",
      "name": "难民营",
      "description": "城墙外的雪地里挤着几顶破帐篷，孩子和老人缩在一起取暖。他们望着紧闭的城门，等一个不知会不会来的答复。",
      "connections": [
        {"to": "gatehouse", "distance": "near", "noise_leak": 0.1, "visual_leak": 0.0, "description": "沿着吊桥回到门楼"}
