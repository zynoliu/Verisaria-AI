{
  "content_pack_id": "skyglass_memory_inquest",
  "schema_version": "2.0",
  "world_premise": {
    "era": "near_future_mountain_arcology",
    "tone": "austere_techno_mystery",
    "central_tension": "A high-altitude mirror-array city plans to erase the worksite memories of accident witnesses to preserve public trust in its weather-control system, while rival factions hide that the array's cooling calculus is already failing."
  },
  "world_book": [
    {
      "entry_id": "skyglass_array_public_function",
      "layer": "canonical_fact",
      "content": "天镜城的高空镜阵把日照反射到山谷农带，并在夜间为冰脊蓄热。没有镜阵调度，山谷不会立刻毁灭，但两周内会出现霜害、粮价暴涨和交通封锁。",
      "access": {"visible_to": {"region": ["skyglass"]}, "hidden_from": {}},
      "confidence_policy": "fact"
    },
    {
      "entry_id": "memory_laundering_public_frame",
      "layer": "public_belief",
      "content": "许多居民相信记忆校准是一种治疗流程：把事故目击者的恐慌片段洗掉，可以防止群体性幻听和镜阵恐慌。",
      "access": {"visible_to": {"region": ["skyglass"]}, "hidden_from": {}},
      "confidence_policy": "belief_not_fact"
    },
    {
      "entry_id": "directorate_memory_safety_line",
      "layer": "faction_propaganda",
      "content": "镜务局反复宣称：塔基工人的记忆已经被辐光噪声污染，若不统一清洗，就会把错误证词扩散成全城谣言。",
      "access": {
        "visible_to": {"faction": ["mirror_directorate", "civic_broadcast", "security"]},
        "hidden_from": {"faction": ["gantry_workers", "valley_families"]}
      },
      "confidence_policy": "belief_not_fact"
    },
    {
      "entry_id": "choir_calibration_dogma",
      "layer": "faction_propaganda",
      "content": "校准唱诗团教导学徒：镜阵只会回应无杂念的城市，公开质疑会污染校准歌谱，导致镜面偏斜。",
      "access": {
        "visible_to": {"faction": ["calibration_choir", "mirror_directorate"]},
        "hidden_from": {"faction": ["gantry_workers"]}
      },
      "confidence_policy": "belief_not_fact"
    },
    {
      "entry_id": "junction_twelve_true_fault",
      "layer": "forbidden_knowledge",
      "content": "十二号接点的低温轴承三周前已经开裂，真正原因是镜务局推迟更换冷却环并伪造了夜间负载曲线。",
      "access": {
        "visible_to": {"clearance": ["audit", "inner_ring"], "profession": ["array_mechanic", "mirror_cartographer"]},
        "hidden_from": {"faction": ["civic_broadcast", "security"]}
      },
      "confidence_policy": "fact"
    },
    {
      "entry_id": "nocturne_load_spike",
      "layer": "canonical_fact",
      "content": "事故当夜的镜面负载峰值来自上层温室私自抽调热能，而不是塔基工人操作错误。",
      "access": {
        "visible_to": {"clearance": ["audit", "inner_ring"], "profession": ["array_mechanic", "mirror_cartographer"]},
        "hidden_from": {}
      },
      "confidence_policy": "fact"
    },
    {
      "entry_id": "worker_lira_hidden_witness",
      "layer": "personal_truth",
      "content": "塔基工人莉拉在事故前看见冷却环读数跳红，并听见调度室要求把警报归类为工人误触。",
      "access": {"visible_to": {"profession": ["gantry_rigger"]}, "hidden_from": {}},
      "confidence_policy": "fact"
    },
    {
      "entry_id": "cartographer_renke_chart_copy",
      "layer": "personal_truth",
      "content": "镜图师任柯保存了一份未提交的方位图副本，上面能看出十二号接点偏斜早于工人换班。",
      "access": {"visible_to": {"profession": ["mirror_cartographer"]}, "hidden_from": {}},
      "confidence_policy": "fact"
    },
    {
      "entry_id": "security_quarantine_rationale",
      "layer": "public_belief",
      "content": "安保队声称限制塔基工人行动是为了防止恐慌扩散，不是为了扣押证人。",
      "access": {"visible_to": {"faction": ["security", "mirror_directorate", "civic_broadcast"]}, "hidden_from": {}},
      "confidence_policy": "belief_not_fact"
    },
    {
      "entry_id": "valley_families_depend_on_heat",
      "layer": "canonical_fact",
      "content": "山谷家庭依赖镜阵余热保住夜间幼苗；若镜阵突然停摆，谷地需要临时燃料、列车通行证和温棚优先权。",
      "access": {"visible_to": {"region": ["skyglass", "low_valley"]}, "hidden_from": {}},
      "confidence_policy": "fact"
    },
    {
      "entry_id": "orchid_house_power_diversion",
      "layer": "forbidden_knowledge",
      "content": "上层兰房为了保住珍稀植株，在事故前夜绕过配给协议抽走了额外热能；这笔热能转移被记入塔基误差。",
      "access": {
        "visible_to": {"clearance": ["inner_ring"], "class": ["upper_arcade"]},
        "hidden_from": {"faction": ["gantry_workers", "valley_families", "security"]}
      },
      "confidence_policy": "fact"
    },
    {
      "entry_id": "broadcast_traitor_script",
      "layer": "faction_propaganda",
      "content": "城市广播准备把反对记忆清洗的人称为破镜派，说他们宁愿让山谷冻死也要保护几段不可靠的工人记忆。",
      "access": {"visible_to": {"faction": ["civic_broadcast", "mirror_directorate"]}, "hidden_from": {"faction": ["gantry_workers"]}},
      "confidence_policy": "belief_not_fact"
    },
    {
      "entry_id": "choir_private_doubt",
      "layer": "personal_truth",
      "content": "唱诗团副领唱瑟芙知道校准歌谱最近频繁失拍，但她害怕承认仪式无效会让学徒被镜务局接管。",
      "access": {"visible_to": {"profession": ["choir_cantor"]}, "hidden_from": {}},
      "confidence_policy": "fact"
    },
    {
      "entry_id": "union_secret_route",
      "layer": "local_rumor",
      "content": "传送廊下方有一条旧检修梯，可以绕过安保队把证人从塔基带到听证厅侧门。",
      "access": {"visible_to": {"faction": ["gantry_workers", "courier_union"], "region": ["skyglass"]}, "hidden_from": {}},
      "confidence_policy": "belief_not_fact"
    },
    {
      "entry_id": "archivist_legal_limit",
      "layer": "canonical_fact",
      "content": "根据天镜城旧章程，记忆清洗必须经过档案署见证、镜务局签令和当事人可撤回听证；任一环节缺失都可暂停流程。",
      "access": {"visible_to": {"profession": ["archivist"], "clearance": ["audit", "inner_ring"]}, "hidden_from": {}},
      "confidence_policy": "fact"
    },
    {
      "entry_id": "silent_bell_deadline",
      "layer": "public_belief",
      "content": "静钟三响后，记忆校准室会开始接收第一批塔基证人。居民知道静钟是流程节点，却不知道可以被合法延期。",
      "access": {"visible_to": {"region": ["skyglass"]}, "hidden_from": {}},
      "confidence_policy": "belief_not_fact"
    },
    {
      "entry_id": "inquest_cannot_judge_private_motive",
      "layer": "canonical_fact",
      "content": "审询员只能用公开证词、可核对记录和当场承诺推动裁定，不能凭空断言 NPC 的隐藏动机。",
      "access": {"visible_to": {"faction": ["all"]}, "hidden_from": {}},
      "confidence_policy": "fact"
    },
    {
      "entry_id": "medicine_memory_side_effect",
      "layer": "forbidden_knowledge",
      "content": "记忆校准药剂会削弱最近七十二小时内的空间判断力，工人被清洗后很难再准确描述事故现场。",
      "access": {"visible_to": {"profession": ["mnemonic_clinician"], "clearance": ["audit"]}, "hidden_from": {"faction": ["civic_broadcast"]}},
      "confidence_policy": "fact"
    },
    {
      "entry_id": "market_heat_token_pressure",
      "layer": "local_rumor",
      "content": "热筹市场已经开始囤积山谷温棚用燃料；如果镜阵事故被证实，低谷家庭会先被涨价吞掉。",
      "access": {"visible_to": {"region": ["skyglass", "low_valley"], "faction": ["courier_union"]}, "hidden_from": {}},
      "confidence_policy": "belief_not_fact"
    },
    {
      "entry_id": "director_alen_private_risk",
      "layer": "personal_truth",
      "content": "艾伦总监知道承认冷却环故障会牵连兰房热能转移和镜务局预算欺瞒；他会要求完整证据链才可能暂停清洗。",
      "access": {"visible_to": {"clearance": ["inner_ring"]}, "hidden_from": {"faction": ["gantry_workers", "civic_broadcast"]}},
      "confidence_policy": "fact"
    }
  ],
